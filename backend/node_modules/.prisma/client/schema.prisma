generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  RECEPTIONIST
  TRAINER
  MEMBER
}

enum MemberStatus {
  Active
  Expired
  Pending
  Suspended
}

enum Gender {
  Male
  Female
}

enum TrainerStatus {
  Active
  OnLeave
}

enum LeadStatus {
  New
  Contacted
  Converted
  Lost
}

enum PaymentStatus {
  Success
  Failed
  Pending
}

enum AttendanceStatus {
  Present
  Excused
}

enum NoticeTargetRole {
  ALL
  MEMBERS
  TRAINERS
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

enum NotificationProvider {
  META
  TWILIO
  AISENSY
  INTERAKT
  DISABLED
}

enum AuditAction {
  LOGIN
  LOGOUT
  MEMBER_ACTION
  MEMBERSHIP_ACTION
  TRAINER_ASSIGNMENT
  ATTENDANCE_ACTION
  PAYMENT_ACTION
  ADMIN_ACTION
  PROFILE_ACTION
  NOTIFICATION_ACTION
}

model User {
  id             String               @id @default(cuid())
  name           String
  email          String               @unique
  phone          String?
  passwordHash   String
  role           UserRole
  memberId       String?              @unique
  trainerId      String?              @unique
  receptionistId String?              @unique
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  member         Member?              @relation(fields: [memberId], references: [id])
  trainer        Trainer?             @relation(fields: [trainerId], references: [id])
  receptionist   Receptionist?        @relation(fields: [receptionistId], references: [id])
  refreshTokens  RefreshToken[]
  resetTokens    PasswordResetToken[]
  auditLogs      AuditLog[]
}

model Member {
  id                  String              @id
  name                String
  email               String              @unique
  phone               String
  status              MemberStatus        @default(Active)
  membershipName      String
  startDate           DateTime
  endDate             DateTime
  assignedTrainerId   String?
  assignedTrainerName String?
  attendanceCount     Int                 @default(0)
  gender              Gender
  activeSlot          String
  balanceDue          Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  user                User?
  assignedTrainer     Trainer?            @relation(fields: [assignedTrainerId], references: [id])
  payments            PaymentRecord[]
  attendance          AttendanceRecord[]
  progress            ProgressMetric[]
  workouts            WorkoutPlan[]
  diets               DietPlan[]
  histories           MembershipHistory[]
  assignments         TrainerAssignment[]

  @@index([status])
  @@index([assignedTrainerId])
}

model Trainer {
  id            String              @id
  name          String
  email         String              @unique
  phone         String
  specialty     String
  assignedCount Int                 @default(0)
  status        TrainerStatus       @default(Active)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  user          User?
  members       Member[]
  assignments   TrainerAssignment[]

  @@index([status])
}

model Receptionist {
  id        String   @id
  name      String
  email     String   @unique
  phone     String
  shift     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?
}

model Lead {
  id        String     @id
  name      String
  phone     String
  email     String?
  interest  String
  status    LeadStatus @default(New)
  date      DateTime   @default(now())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
}

model MembershipPlan {
  id                 String   @id @default(cuid())
  name               String   @unique
  durationMonths     Int
  price              Int
  isPersonalTraining Boolean  @default(false)
  createdAt          DateTime @default(now())
}

model MembershipHistory {
  id        String   @id @default(cuid())
  memberId  String
  planName  String
  startDate DateTime
  endDate   DateTime
  amount    Int
  action    String
  createdAt DateTime @default(now())
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

model TrainerAssignment {
  id         String    @id @default(cuid())
  memberId   String
  trainerId  String
  assignedAt DateTime  @default(now())
  removedAt  DateTime?
  member     Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  trainer    Trainer   @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([trainerId])
}

model PaymentRecord {
  id                 String         @id
  memberId           String
  memberName         String
  amount             Int
  paymentDate        DateTime       @default(now())
  planName           String
  status             PaymentStatus  @default(Success)
  paymentMethod      String
  expiryExtendedDate DateTime
  receiptNumber      String         @unique
  createdAt          DateTime       @default(now())
  member             Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  receipt            ReceiptRecord?

  @@index([memberId])
  @@index([status])
}

model ReceiptRecord {
  id            String        @id @default(cuid())
  paymentId     String        @unique
  receiptNumber String        @unique
  storageKey    String?
  generatedAt   DateTime      @default(now())
  payment       PaymentRecord @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model AttendanceRecord {
  id          String           @id
  memberId    String
  memberName  String
  date        DateTime
  checkInTime String
  status      AttendanceStatus @default(Present)
  createdAt   DateTime         @default(now())
  member      Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, date])
}

model Notice {
  id         String           @id
  title      String
  content    String
  date       DateTime         @default(now())
  author     String
  targetRole NoticeTargetRole @default(ALL)
}

model WorkoutPlan {
  id           String            @id
  memberId     String
  title        String
  dateAssigned DateTime          @default(now())
  member       Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  exercises    WorkoutExercise[]

  @@index([memberId])
}

model WorkoutExercise {
  id            String      @id @default(cuid())
  workoutPlanId String
  day           String
  routine       String
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
}

model DietPlan {
  id           String     @id
  memberId     String
  title        String
  calories     Int
  proteinGrams Int
  dateAssigned DateTime   @default(now())
  member       Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  meals        DietMeal[]

  @@index([memberId])
}

model DietMeal {
  id         String   @id @default(cuid())
  dietPlanId String
  time       String
  intake     String
  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)
}

model ProgressMetric {
  id             String   @id
  memberId       String
  date           DateTime @default(now())
  weight         Float
  bmi            Float
  muscleMass     Float
  bodyFatPercent Float
  notes          String
  member         Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, date])
}

model NotificationTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  channel   String
  body      String
  createdAt DateTime @default(now())
}

model NotificationQueueItem {
  id             String               @id @default(cuid())
  provider       NotificationProvider @default(DISABLED)
  recipientPhone String
  templateKey    String
  payload        Json
  status         NotificationStatus   @default(PENDING)
  scheduledFor   DateTime
  attempts       Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model NotificationLog {
  id                String               @id @default(cuid())
  provider          NotificationProvider
  recipientPhone    String
  templateKey       String
  status            NotificationStatus
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime             @default(now())
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())
  user       User?       @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
